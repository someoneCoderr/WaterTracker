<Window x:Class="WaterTracker.Views.HomeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WaterTracker"
        xmlns:viewModel="clr-namespace:WaterTracker.ViewModel"
        d:DataContext="{d:DesignInstance Type=viewModel:HomeViewModel}"
        mc:Ignorable="d"
        Title="WaterTracker" MinHeight="700" MinWidth="500">

    <Grid Background="#0F172A">
        <Grid Margin="16" MinHeight="620" MaxHeight="1000">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Style="{StaticResource Card}" Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="Heute" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                        <TextBlock Text="{Binding TodayTotalMl}" Foreground="{StaticResource TextBrush}" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="ml" Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="6,12,0,0"/>
                        <TextBlock Text=" / " Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="10,12,0,0"/>
                        <TextBlock Text="{Binding DailyGoalMl}" Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="0,12,0,0"/>
                        <TextBlock Text="ml" Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="6,12,0,0"/>
                    </StackPanel>

                    <ProgressBar Height="14" Maximum="100"
                            Value="{Binding ProgressPercent, Mode=OneWay}"
                            Background="#0B1222"
                            Foreground="{StaticResource AccentBrush}"/>

                    <TextBlock Margin="0,10,0,0"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="{Binding ProgressText}"/>
                </StackPanel>
            </Border>

            <!-- QUICK ADD -->
            <Border Style="{StaticResource Card}" Grid.Row="1">
                <StackPanel>
                    <TextBlock Text="Schnell hinzufügen" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <UniformGrid Columns="4" Rows="1" HorizontalAlignment="Stretch">
                        <Button Style="{StaticResource QuickButton}" Content="+100" Command="{Binding AddPresetCommand}" CommandParameter="100"/>
                        <Button Style="{StaticResource QuickButton}" Content="+250" Command="{Binding AddPresetCommand}" CommandParameter="250"/>
                        <Button Style="{StaticResource QuickButton}" Content="+500" Command="{Binding AddPresetCommand}" CommandParameter="500"/>
                        <Button Style="{StaticResource QuickButton}" Content="+750" Command="{Binding AddPresetCommand}" CommandParameter="750"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- CUSTOM INPUT -->
            <Border Style="{StaticResource Card}" Grid.Row="2">
                <StackPanel>
                    <TextBlock Text="Eigene Menge (ml)" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="43.854"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                            Text="{Binding CustomAmountText, UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="2" Margin="0,0,12,0"/>

                        <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButton}"
                        Content="Hinzufügen"
                        Command="{Binding AddCustomCommand}" Grid.ColumnSpan="2"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="{Binding ErrorText}" Foreground="#FF6B6B"/>
                        <Button Content="Ziel ändern"
                        Background="Transparent"
                        Foreground="{StaticResource AccentBrush}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding OpenGoalCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- HISTORY -->
            <Border Style="{StaticResource Card}" Grid.Row="3" MinHeight="100"
                    BorderBrush="{StaticResource BorderBrush}">
                <Expander IsExpanded="True" Background="Transparent" Foreground="{StaticResource TextBrush}" DockPanel.Dock="Top">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="History" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedDateLabel}" Foreground="{StaticResource TextMutedBrush}" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>

                    <DockPanel Margin="0,10,0,0" LastChildFill="True">
                        <DatePicker SelectedDate="{Binding SelectedDate}" DockPanel.Dock="Top"/>

                        <ListBox ItemsSource="{Binding Entries}"
                                 SelectedItem="{Binding SelectedWaterEntry}"
                                Margin="0,10,0,0" 
                                Background="#0B1222" 
                                BorderBrush="{StaticResource BorderBrush}" 
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TimeText}" Foreground="{StaticResource TextMutedBrush}" Width="70"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AmountText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <Button Grid.Column="2" Width="16" Height="16" Margin="10,0,0,0" Cursor="Hand" 
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.EditEntryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                            <Image Source="/Resources/editWhite.png" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Expander>
            </Border>
        </Grid>
    </Grid>
</Window>
